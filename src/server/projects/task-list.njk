{% extends 'layouts/page.njk' %}
{% from "govuk/components/task-list/macro.njk" import govukTaskList %}


{% block content %}
  {{ appHeading({
    text: heading
  }) }}

  <div class="govuk-grid-row">
    <div class="govuk-grid-column-two-thirds">
      <p class="govuk-body">When you provide your information:</p>
      <ul class="govuk-list govuk-list--bullet">
        <li>you’ll need to complete each section before you can send the information</li>
        <li>you can still make changes to a section even after it is marked complete</li>
        <li>you can save your progress at the end of each section if you need to come back later</li>
      </ul>
      {{
        govukTaskList({
          idPrefix: "project-task-list",
          items: [
            {
              title: {
              text: "Project Name"
              },
              status: {
                text: "Completed"
              }
            },
            {
              title: {
                text: "Project Details"
              },
              status: {
                tag: {
                  text: "Not yet started",
                  classes: "govuk-tag--blue"
                }
              }
            },
            {
              title: {
                text: "On-site baseline habitats"
              },
              status: {
                tag: {
                  text: "Not yet started",
                  classes: "govuk-tag--blue"
                }
              }
            },
            {
              title: {
                text: "On-site post intervention habitats"
              },
              status: {
                text: "Incomplete"
              }
            }
          ]
        })
      }}
      <a class="govuk-link" href="/project-dashboard">Back to projects</a>
    </div>
  </div>
{% endblock %}
