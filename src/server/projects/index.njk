{% extends 'layouts/page.njk' %}

{% from "govuk/components/button/macro.njk" import govukButton %}

{% block content %}
  <div class="govuk-grid-row app-heading" data-testid="app-heading">
    <div class="govuk-grid-column-two-thirds">
      <h1 class="govuk-heading-l govuk-!-margin-bottom-2" data-testid="app-heading-title">
        {{ heading }}
      </h1>
    </div>
    <div class="govuk-grid-column-one-third app-heading-secondary-info">
      {{ govukButton({
        text: "Create new project",
        href: "/define-project-name",
        classes: "govuk-!-margin-bottom-0"
      }) }}
    </div>
  </div>

  <div class="govuk-grid-row">
    <div class="govuk-grid-column-full">
      {% if projects | length %}
        <table class="govuk-table" data-testid="projects-table">
          <thead class="govuk-table__head">
            <tr class="govuk-table__row">
              <th scope="col" class="govuk-table__header">Project name</th>
              <th scope="col" class="govuk-table__header">Last modified</th>
              <th scope="col" class="govuk-table__header">Date created</th>
            </tr>
          </thead>
          <tbody class="govuk-table__body">
            {% for item in projects %}
              <tr class="govuk-table__row">
                <td class="govuk-table__cell">
                  <a class="govuk-link" href="/project-task-list/{{ item.id }}">{{ item.project.name }}</a>
                </td>
                <td class="govuk-table__cell">
                  {{ item.updatedAt | formatDate("d MMMM yyyy 'at' h:mmaaa") if item.updatedAt else '—' }}
                </td>
                <td class="govuk-table__cell">
                  {{ item.createdAt | formatDate('d MMMM yyyy') if item.createdAt else '—' }}
                </td>
              </tr>
            {% endfor %}
          </tbody>
        </table>
      {% else %}
        <p class="govuk-body-l govuk-!-font-weight-bold" data-testid="no-projects">No projects started.</p>
      {% endif %}
    </div>
  </div>
{% endblock %}
