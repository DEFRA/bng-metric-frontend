{% extends 'layouts/page.njk' %}

{% from "govuk/components/file-upload/macro.njk" import govukFileUpload %}
{% from "govuk/components/button/macro.njk" import govukButton %}
{% from "govuk/components/error-summary/macro.njk" import govukErrorSummary %}
{% from "govuk/components/details/macro.njk" import govukDetails %}

{% block beforeContent %}
  {{ super() }}
  <nav>
    <a class="govuk-back-link" href="/projects/{{ projectId }}">Back</a>
  </nav>
{% endblock %}

{% block content %}
  {% if uploadError or error %}
    {{ govukErrorSummary({
      titleText: "There is a problem",
      errorList: [
        {
          text: error.text if error else uploadError,
          href: "#file"
        }
      ]
    }) }}
  {% endif %}

  {{ appHeading({
    text: heading,
    caption: caption
  }) }}

  <div class="govuk-grid-row">
    <div class="govuk-grid-column-two-thirds">
      {% if uploadUrl %}
        <p class="govuk-body">{{ instructionText }}</p>
        <p class="govuk-body">{{ secondaryText }}</p>

        {{ govukDetails({
          summaryText: "What layers should my file contain?",
          html: '<p class="govuk-body">Your GeoPackage file should contain layers for:</p>
          <ul class="govuk-list govuk-list--bullet">
            <li>Red line boundary</li>
            <li>Baseline habitat parcels</li>
          </ul>'
        }) }}

        <template id="tpl-error-summary">
          {{ govukErrorSummary({
            titleText: "There is a problem",
            attributes: { "data-client-error": "true" }
          }) }}
        </template>

        <template id="tpl-error-message">
          <p class="govuk-error-message">
            <span class="govuk-visually-hidden">Error:</span>
            <span data-error-text></span>
          </p>
        </template>

        {# Posts to the CDP uploader service, not this app — no appForm/crumb. #}
        <form action="{{ uploadUrl }}" method="post" enctype="multipart/form-data" novalidate>
          {{ govukFileUpload({
            id: "file",
            name: "file",
            label: {
              text: "Upload a file"
            },
            attributes: {
              accept: ".gpkg"
            },
            javascript: true,
            chooseFilesButtonText: "Choose file",
            dropzoneText: "or drop file",
            noFileChosenText: "No file chosen",
            errorMessage: { text: error.text } if error else undefined
          }) }}

          <div class="govuk-button-group">
            {{ govukButton({
              text: "Continue"
            }) }}

            <a class="govuk-link" href="/projects/{{ projectId }}">Cancel</a>
          </div>
        </form>
      {% else %}
        <p class="govuk-body">Unable to start file upload. Please try again later.</p>
      {% endif %}
    </div>
  </div>
{% endblock %}
