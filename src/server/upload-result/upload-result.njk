{% extends 'layouts/page.njk' %}

{% block pageTitle %}{{ pageTitle }}{% endblock %}

{% block content %}
  {{ appHeading({
    text: heading
  }) }}

  <div class="govuk-grid-row">
    <div class="govuk-grid-column-two-thirds">
      <p class="govuk-body">Your baseline file has been uploaded and passed validation.</p>
      <p class="govuk-body">
