{% extends 'layouts/page.njk' %}

{% block beforeContent %}
  {{ super() }}
  <nav>
    <a class="govuk-back-link" href="/projects/{{ projectId }}/upload-baseline-file">Back</a>
  </nav>
{% endblock %}

{% block content %}
  {{ appHeading({
    text: heading
  }) }}

  <div class="govuk-grid-row">
    <div class="govuk-grid-column-two-thirds">
      <p class="govuk-body">Your baseline file has been uploaded and passed validation.</p>
      <p class="govuk-body">
        <a class="govuk-link" href="/project-task-list/{{ projectId }}">Return to project</a>
      </p>
    </div>
  </div>
{% endblock %}
